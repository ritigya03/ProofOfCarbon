# ── Polygon Amoy Testnet ──────────────────────────────────────────────────────
# Get a free RPC from: https://www.alchemy.com/ or https://www.quicknode.com/
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Your wallet private key (MetaMask → Account Details → Export Private Key)
# ⚠️  NEVER commit this file to git. It is already in .gitignore.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Polygon Mainnet (production only) ────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Polygonscan API key (for contract verification) ──────────────────────────
# Get one at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ── Sepolia (keep for reference) ─────────────────────────────────────────────
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
