# LLM
LLM_PROVIDER=groq         # or openai
LLM_API_KEY=your_groq_or_openai_key_here

# Blockchain
RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=your_wallet_private_key_here
CONTRACT_ADDRESS=your_deployed_contract_address_here

# Reference data paths (local GeoJSON fallback when PostGIS is not available)
FOREST_REFERENCE_PATH=data/reference/india_forest_cover.geojson
PROTECTED_AREAS_PATH=data/reference/india_protected_areas.geojson

# PostGIS (optional — for production-scale spatial queries)
POSTGIS_URL=postgresql://poc:poc_secret@localhost:5432/proofofcarbon

# ── Satellite Evidence (SatelliteEvidenceAgent) ───────────────────────────────
# When these are NOT set, the agent uses a deterministic mock — no setup needed.
# To use real NASA MODIS data:
#   1. Sign up free at https://signup.earthengine.google.com
#   2. Create a service account + JSON key in Google Cloud Console
#   3. Set the two variables below
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_KEY=/path/to/your/gee-service-account-key.json
